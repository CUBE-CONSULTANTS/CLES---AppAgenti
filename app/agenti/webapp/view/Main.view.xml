<mvc:View
    xmlns:uxap="sap.uxap"
    displayBlock="true"
    controllerName="cles.agenti.controller.Main"
    height="100%"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <f:DynamicPage
        class="sapUiNoContentPadding"
        preserveHeaderStateOnScroll="false"
        stickySubheaderProvider="iconTabBar"
        headerExpanded="true"
        headerPinned="false"
        showFooter="true"
        fitContent="false"
    >
        <!-- DynamicPage Title -->
        <f:title>
            <core:Fragment
                fragmentName="cles.agenti.view.fragment.main.HeaderTitle"
                type="XML"
            />
        </f:title>

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.main.HeaderContent"
                />
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <IconTabBar
                id="iconTabBar"
                applyContentPadding="false"
                expandable="false"
                expanded="true"
                stretchContentHeight="false"
                select=".onObjectPageSectionChange"
                selectedKey="{proposta>/activeTab}"
            >
                <items>
                    <IconTabFilter
                        key="storico"
                        text="Storico Ordini"
                        visible="{= 
                        (${proposta>/header/mode} === 'ORDINE' &amp;&amp; ${proposta>/header/tabOrdine} === 'STORICO') ? true :
                        ${proposta>/header/mode} === 'OFFERTA' ? true :
                        false 
                      }"
                    >
                        <content>
                            <core:Fragment
                                fragmentName="cles.agenti.view.fragment.main.tab.StoricoOrdini"
                                type="XML"
                            />
                        </content>
                    </IconTabFilter>
                    <IconTabFilter
                        key="offerta"
                        text="{proposta>/header/tabOfferta/name} (Valida fino al {proposta>/header/tabOfferta/expiry})"
                        visible="{= (${proposta>/header/mode} === 'ORDINE' &amp;&amp; ${proposta>/header/tabOrdine} === 'OFFERTA') ? true : false }"
                    >
                        <content>
                            <core:Fragment
                                fragmentName="cles.agenti.view.fragment.main.tab.Offerta"
                                type="XML"
                            />
                        </content>
                    </IconTabFilter>
                    <IconTabFilter
                        key="proposta"
                        text="Proposta Prodotti"
                        visible="{= (${proposta>/header/mode} === 'ORDINE' || ${proposta>/header/mode} === 'OFFERTA') ? true : false }"
                    >
                        <content>
                            <core:Fragment
                                fragmentName="cles.agenti.view.fragment.main.tab.PropostaProdotti"
                                type="XML"
                            />
                        </content>
                    </IconTabFilter>
                    <IconTabFilter
                        key="catalogo"
                        text="Catalogo"
                    >
                        <content>
                            <core:Fragment
                                fragmentName="cles.agenti.view.fragment.main.tab.Catalogo"
                                type="XML"
                            />
                        </content>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </f:content>
        <!-- DynamicPage Footer -->
        <f:footer>
            <core:Fragment
                fragmentName="cles.agenti.view.fragment.main.Footer"
                type="XML"
            />
        </f:footer>
    </f:DynamicPage>
</mvc:View>
