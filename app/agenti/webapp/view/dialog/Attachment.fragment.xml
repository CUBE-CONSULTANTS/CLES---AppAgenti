<core:FragmentDefinition
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog showHeader="false">
        <content>
            <VBox class="sapUiContentPadding">
                <VBox class="sapUiSmallMargin">
                    <core:HTML
                        content="&lt;div id='cameraContainer'&gt;&lt;/div&gt;"
                    />

                    <HBox
                        justifyContent="Center"
                        class="sapUiSmallMargin"
                    >
                        <Button
                            class="sapUiTinyMargin"
                            type="Emphasized"
                            text="Scatta Foto"
                            press=".onTakePhoto"
                        />
                        <Button
                            class="sapUiTinyMargin"
                            type="Emphasized"
                            text="Avvia Registrazione"
                            press=".onStartRecording"
                        />
                        <Button
                            class="sapUiTinyMargin"
                            type="Emphasized"
                            text="Stop Registrazione"
                            press=".onStopRecording"
                        />
                    </HBox>
                </VBox>
                <VBox class="sapUiSmallMargin">
                    <Label
                        text="Carica un allegato"
                        design="Bold"
                    />
                    <u:FileUploader
                        width="100%"
                        style="Emphasized"
                        name="myFileUpload"
                        uploadUrl="upload/"
                        value="{/value}"
                        uploadComplete="handleUploadComplete"
                    />
                </VBox>

                <ScrollContainer
                    vertical="true"
                    horizontal="false"
                >
                    <List
                        items="{/attachments/items}"
                        sticky="HeaderToolbar"
                    >
                        <items>
                            <CustomListItem
                                type="Active"
                                press=".onHeaderAttachmentItemPress"
                            >
                                <HBox
                                    width="100%"
                                    alignItems="Center"
                                    justifyContent="SpaceBetween"
                                >
                                    <Text
                                        class="sapUiTinyMarginBeginEnd"
                                        wrapping="true"
                                        text="{data}"
                                    />
                                    <Text
                                        class="sapUiTinyMarginBeginEnd"
                                        wrapping="true"
                                        text="{nome}"
                                    />
                                    <Button
                                        class="sapUiTinyMarginBeginEnd"
                                        type="Negative"
                                        icon="sap-icon://delete"
                                        press=".onHeaderAttachmentDeletePress"
                                    />
                                </HBox>
                            </CustomListItem>
                        </items>
                    </List>
                </ScrollContainer>
            </VBox>
        </content>
        <buttons>
            <Button
                text="Upload"
                enabled="{= ${/value} ? true : false }"
                type="Emphasized"
                press=".defaultDialogClose"
            />
            <Button
                text="Chiudi"
                type="Emphasized"
                press=".defaultDialogClose"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
