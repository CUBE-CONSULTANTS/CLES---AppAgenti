<core:FragmentDefinition
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        contentWidth="{= ${device>/system/phone} ? '100%' : '40%'}"
        showHeader="true"
        title="Crea Segnalazione"
    >
        <content>
            <form:SimpleForm layout="ResponsiveGridLayout"
                columnsL="2"
                columnsM="2">
                <Label
                    text="Tipologia"
                    design="Bold"
                />
                <RadioButtonGroup>
                    <RadioButton
                        text="Segnalazione Prodotto"
                        selected="true"
                    />
                    <RadioButton text="Modifica Anagrafica" />
                </RadioButtonGroup>
                <Label
                    text="Note"
                    design="Bold"
                />
                <TextArea rows="4" />
            </form:SimpleForm>
        </content>
        <buttons>
            <Button
                text="Invia"
                type="Emphasized"
                press=".defaultDialogClose"
            />
            <Button
                text="Chiudi"
                type="Emphasized"
                press=".defaultDialogClose"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
