<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <VBox>
        <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            columnsL="2"
            columnsM="2"
            emptySpanXL="4"
            emptySpanL="4"
        >
            <form:content>
                <Label
                    text="Cliente"
                    design="Bold"
                />
                <Input
                    editable="false"
                    value="{/step2/customer/name}"
                />
                <Label
                    text="Visualizzazione tab"
                    design="Bold"
                />
                <SegmentedButton
                    selectedKey="{/step3/tab/selected}"
                    items="{/step3/tab/items}"
                >
                    <items>
                        <SegmentedButtonItem
                            key="{key}"
                            text="{text}"
                        />
                    </items>
                </SegmentedButton>
            </form:content>
        </form:SimpleForm>
        <List
            visible="{= ${/step3/tab/selected} === 'OFFERTA' ? true : false }"
            mode="SingleSelectLeft"
            items="{/step3/offer/items}"
            rememberSelections="true"
            includeItemInSelection="true"
            selectionChange=".onCustomerOfferSelectionChange"
        >
            <items>
                <StandardListItem
                    selected="{selected}"
                    title="{name}"
                    description="{expiry}"
                />
            </items>
        </List>
    </VBox>
</core:FragmentDefinition>
