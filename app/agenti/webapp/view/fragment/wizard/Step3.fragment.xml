<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <VBox>
        <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            columnsL="2"
            columnsM="2"
            emptySpanXL="4"
            emptySpanL="4"
        >
            <form:content>
                <Label
                    text="Cliente"
                    design="Bold"
                />
                <Input
                    editable="false"
                    value="{/step2/customer/name}"
                />
            </form:content>
        </form:SimpleForm>
        <List
            visible="{= ${/step2/tab/selected} === 'OFFERTA' ? true : false }"
            mode="SingleSelectLeft"
            items="{/step3/offer/items}"
            rememberSelections="true"
            includeItemInSelection="true"
            selectionChange=".onCustomerOfferSelectionChange"
        >
            <items>
                <StandardListItem
                    selected="{selected}"
                    title="{name}"
                    description="{expiry}"
                />
            </items>
        </List>
    </VBox>
</core:FragmentDefinition>
