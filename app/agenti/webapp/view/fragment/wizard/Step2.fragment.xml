<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <HBox
        class="sapUiTinyMarginBottom"
        width="100%"
        alignItems="Center"
        wrap="Wrap"
        visible="{= ${/selectedMode} === 'PREORDINE' ? false : true }"
    >
        <VBox width="100%">
            <Label
                required="true"
                text="{= ${/selectedMode} === 'ORDINE' ? 'Data di Consegna:' : 'Data di Validità:' }"
                design="Bold"
            />
            <SegmentedButton
                selectedKey="today"
                contentMode="ContentFit"
            >
                <items>
                    <SegmentedButtonItem
                        key="today"
                        text="Oggi"
                    />
                    <SegmentedButtonItem
                        key="tomorrow"
                        text="Domani"
                    />
                </items>
            </SegmentedButton>
        </VBox>

        <VBox class="sapUiTinyMarginTop">
            <DatePicker dateValue="{/step2/date/value}" />
        </VBox>
    </HBox>
    <VBox
        class="sapUiTinyMarginBottom"
        fitContainer="true"
        height="100%"
        visible="{= ${/selectedMode} === 'PREORDINE' ? false : true }"
    >
        <core:Fragment fragmentName="cles.agenti.view.fragment.customer.List" />
    </VBox>
    <VBox
        class="sapUiTinyMarginBottom"
        visible="{= ${/selectedMode} === 'PREORDINE' ? true : false }"
    >
        <core:Fragment fragmentName="cles.agenti.view.fragment.preorder.Form" />
    </VBox>
</core:FragmentDefinition>
