<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:richtexteditor="sap.ui.richtexteditor"
>
    <HBox
        class="sapUiTinyMarginBottom"
        width="100%"
        alignItems="Center"
        wrap="Wrap"
        visible="{= ${/selectedMode} === 'PREORDINE' ? false : true }"
    >
        <VBox width="100%">
            <Label
                required="true"
                text="{= ${/selectedMode} === 'ORDINE' ? 'Data di Consegna:' : 'Data di Validità:' }"
                design="Bold"
            />
        </VBox>
        <VBox class="sapUiTinyMarginEnd">
            <DatePicker dateValue="{/step2/date/value}" />
        </VBox>
        <HBox>
            <Button
                class="sapUiTinyMarginEnd"
                text="Oggi"
                icon="sap-icon://date-time"
                type="Neutral"
                press=".onStep2DateButtonPress"
            >
                <customData>
                    <core:CustomData
                        key="dateBtn"
                        value="today"
                    />
                </customData>
            </Button>
            <Button
                text="Domani"
                icon="sap-icon://date-time"
                type="Default"
                press=".onStep2DateButtonPress"
            >
                <customData>
                    <core:CustomData
                        key="dateBtn"
                        value="tomorrow"
                    />
                </customData>
            </Button>
        </HBox>
    </HBox>
    <VBox
        class="sapUiTinyMarginBottom"
        width="100%"
        justifyContent="Center"
        wrap="Wrap"
        visible="{= ${/selectedMode} === 'ORDINE' ? true : false }"
    >
        <Label
            text="Visualizzazione tab:"
            required="true"
            design="Bold"
        />
        <SegmentedButton
            width="{= ${device>/system/desktop} ? '40%' : '100%'}"
            contentMode="EqualSized"
            selectedKey="{/step2/tab/selected}"
            items="{/step2/tab/items}"
        >
            <items>
                <SegmentedButtonItem
                    key="{key}"
                    text="{text}"
                />
            </items>
        </SegmentedButton>
    </VBox>
    <VBox
        class="sapUiTinyMarginBottom"
        fitContainer="true"
        height="100%"
        visible="{= ${/selectedMode} === 'PREORDINE' ? false : true }"
    >
        <core:Fragment fragmentName="cles.agenti.view.fragment.customer.List" />
    </VBox>
    <VBox
        class="sapUiTinyMarginBottom"
        visible="{= ${/selectedMode} === 'PREORDINE' ? true : false }"
    >
        <core:Fragment fragmentName="cles.agenti.view.fragment.preorder.Form" />
    </VBox>
</core:FragmentDefinition>
