<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:richtexteditor="sap.ui.richtexteditor"
>
    <HBox
        class="sapUiTinyMarginBottom"
        width="100%"
        alignItems="Center"
        wrap="Wrap"
        visible="{= ${/selectedMode} === 'PREORDINE' ? false : true }"
    >
        <VBox width="100%">
            <Label
                required="true"
                text="{= ${/selectedMode} === 'ORDINE' ? 'Data di Consegna:' : 'Data di Validità:' }"
                design="Bold"
            />
        </VBox>

        <Button
            class="sapUiTinyMarginEnd"
            text="Oggi"
            icon="sap-icon://date-time"
            type="Default"
            press=".onStep2DateButtonPress"
        >
            <customData>
                <core:CustomData
                    key="dateBtn"
                    value="today"
                />
            </customData>
        </Button>
        <Button
            class="sapUiTinyMarginEnd"
            text="Domani"
            icon="sap-icon://date-time"
            type="Default"
            press=".onStep2DateButtonPress"
        >
            <customData>
                <core:CustomData
                    key="dateBtn"
                    value="tomorrow"
                />
            </customData>
        </Button>
        <DatePicker dateValue="{/step2/date/value}" />
    </HBox>
    <VBox
        class="sapUiTinyMarginBottom"
        width="100%"
        justifyContent="Center"
        wrap="Wrap"
        visible="{= ${/selectedMode} === 'ORDINE' ? true : false }"
    >
        <Label
            text="Visualizzazione tab:"
            required="true"
            design="Bold"
        />
        <SegmentedButton
            selectedKey="{/step2/tab/selected}"
            items="{/step2/tab/items}"
        >
            <items>
                <SegmentedButtonItem
                    key="{key}"
                    text="{text}"
                />
            </items>
        </SegmentedButton>
    </VBox>
    <VBox
        class="sapUiTinyMarginBottom"
        fitContainer="true"
        height="100%"
        visible="{= ${/selectedMode} === 'PREORDINE' ? false : true }"
    >
        <core:Fragment fragmentName="cles.agenti.view.fragment.customer.List" />
    </VBox>
    <VBox
        class="sapUiTinyMarginBottom"
        visible="{= ${/selectedMode} === 'PREORDINE' ? true : false }"
    >
        <core:Fragment fragmentName="cles.agenti.view.fragment.preorder.Form" />
    </VBox>
</core:FragmentDefinition>
