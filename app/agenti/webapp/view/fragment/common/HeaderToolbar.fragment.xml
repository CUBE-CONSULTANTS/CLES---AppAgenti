<core:FragmentDefinition xmlns:vk="sap.ui.vk" 
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <OverflowToolbar
        design="Solid"
        style="Clear"
    >
        <SearchField
            width="{= ${device>/system/phone} ? 'auto' : '20rem' }"
            placeholder="Cerca per categoria o codice/descrizione"
            showSearchButton="false"
            liveChange=".onSearch"
        />
        <ToolbarSpacer />
        <ToggleButton
            pressed="{proposta>/table/toolbar/showImages}"
            text="Immagini"
            type="Critical"
            icon="{= ${proposta>/table/toolbar/showImages} ? 'sap-icon://show' : 'sap-icon://hide'}"
        />
        <ToggleButton
            pressed="{proposta>/table/toolbar/showQuantity}"
            text="Disponibilità"
            type="Success"
            icon="{= ${proposta>/table/toolbar/showQuantity} ? 'sap-icon://show' : 'sap-icon://hide'}"
        />
        <ToggleButton
            pressed="{proposta>/table/toolbar/showAttributes}"
            text="Attributi"
            type="Reject"
            icon="{= ${proposta>/table/toolbar/showAttributes} ? 'sap-icon://show' : 'sap-icon://hide'}"
        />
        <ToolbarSeparator />
        <ToggleButton
            pressed="{proposta>/table/toolbar/sorters/groupedByCategory}"
            press=".onGroupByCategory"
            text="Raggruppa per Categoria"
            icon="sap-icon://group-2"
        />
        <ToolbarSeparator />
        <MenuButton
            text="Descrizione"
            type="Emphasized"
            icon="sap-icon://sort"
        >
            <menu>
                <Menu>
                    <items>
                        <MenuItem
                            press=".onSortByDescriptionAsc"
                            text="Ordine Ascendente"
                            icon="sap-icon://sort-ascending"
                        />
                        <MenuItem
                            press=".onSortByDescriptionDesc"
                            text="Ordine Discendente"
                            icon="sap-icon://sort-descending"
                        />
                    </items>
                </Menu>
            </menu>
        </MenuButton>
        <MenuButton
            text="Categoria"
            type="Emphasized"
            icon="sap-icon://sort"
        >
            <menu>
                <Menu>
                    <items>
                        <MenuItem
                            press=".onSortByCategoryAsc"
                            text="Ordine Ascendente"
                            icon="sap-icon://sort-ascending"
                        />
                        <MenuItem
                            press=".onSortByCategoryDesc"
                            text="Ordine Discendente"
                            icon="sap-icon://sort-descending"
                        />
                    </items>
                </Menu>
            </menu>
        </MenuButton>
    </OverflowToolbar>
</core:FragmentDefinition>
