<core:FragmentDefinition
    xmlns:grid="sap.ui.layout.cssgrid"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
>
    <grid:CSSGrid class="sapUiTinyMarginTop">
        <grid:customLayout>
            <grid:GridResponsiveLayout>
                <grid:layoutS>
                    <grid:GridSettings
                        gridTemplateColumns="1fr"
                        gridGap="0.5rem"
                    />
                </grid:layoutS>
                <grid:layoutM>
                    <grid:GridSettings
                        gridTemplateColumns="1fr 1fr"
                        gridGap="0.5rem"
                    />
                </grid:layoutM>
                <grid:layoutL>
                    <grid:GridSettings
                        gridTemplateColumns="1fr 1fr"
                        gridGap="0.5rem"
                    />
                </grid:layoutL>
                <grid:layoutXL>
                    <grid:GridSettings
                        gridTemplateColumns="1fr 1fr"
                        gridGap="0.5rem"
                    />
                </grid:layoutXL>
            </grid:GridResponsiveLayout>
        </grid:customLayout>
        <VBox>
            <Label
                text="Categorie"
                design="Bold"
            />
            <MultiComboBox
                placeholder="Categorie"
                selectionChange=".onFiltriCategorieSelectionChange"
                items="{
                  path: 'proposta>/table/toolbar/filtri/categorie', 
                  sorter: { path: 'text', descending: false}
                }"
            >
                <items>
                    <core:Item
                        key="{proposta>key}"
                        text="{proposta>text}"
                    />
                </items>
            </MultiComboBox>
        </VBox>

        <VBox>
            <Label
                text="Gruppi Materiale"
                design="Bold"
            />
            <MultiComboBox
                selectionChange=".onFiltriGruppiSelectionChange"
                placeholder="Gruppi Materiale"
                items="{
                  path: 'proposta>/table/toolbar/filtri/gruppi', 
                  sorter: { path: 'text', descending: false}
                }"
            >
                <items>
                    <core:Item
                        key="{proposta>key}"
                        text="{proposta>text}"
                    />
                </items>
            </MultiComboBox>
        </VBox>
    </grid:CSSGrid>
    <VBox
        width="100%"
        class="sapUiTinyMarginTop"
    >
        <Label
            text="Attributi"
            design="Bold"
        />
        <HeaderContainer
            showDividers="true"
            gridLayout="false"
            scrollStepByItem="2"
            showOverflowItem="true"
            content="{
              path: 'proposta>/table/toolbar/filtri/attributi', 
              sorter: { path: 'text', descending: false}
            }"
        >
            <Button
                press=".onFilterAttributePress"
                text="{proposta>text}"
                type="{proposta>type}"
            />
        </HeaderContainer>
    </VBox>
</core:FragmentDefinition>
