    <VBox
        width="100%"
        class="sapUiTinyMarginTop"
    >
        <Label
            text="Categorie"
            design="Bold"
        />
        <MultiComboBox
            placeholder="Categorie"
            items="{
                      path: 'proposta>/table/toolbar/filtri/categorie', 
                      sorter: { path: 'text', descending: false}
                    }"
        >
            <items>
                <core:Item
                    key="{proposta>key}"
                    text="{proposta>text}"
                />
            </items>
        </MultiComboBox>
    </VBox>
    <VBox
        width="100%"
        class="sapUiTinyMarginTop"
    >
        <Label
            text="Gruppi Materiale"
            design="Bold"
        />
        <MultiComboBox
            placeholder="Gruppi Materiale"
            items="{
              path: 'proposta>/table/toolbar/filtri/gruppi', 
              sorter: { path: 'text', descending: false}
            }"
        >
            <items>
                <core:Item
                    key="{proposta>key}"
                    text="{proposta>text}"
                />
            </items>
        </MultiComboBox>
    </VBox>
    <VBox width="100%" class="sapUiTinyMarginTop">
        <Label
            text="Attributi"
            design="Bold"
        />
        <HeaderContainer
            showDividers="true"
            gridLayout="false"
            scrollStepByItem="2"
            showOverflowItem="true"
            content="{
              path: 'proposta>/table/toolbar/filtri/attributi', 
              sorter: { path: 'text', descending: false}
            }"
        >
            <Button
                press=".onFilterAttributePress"
                text="{proposta>text}"
                type="{proposta>type}"
            />
        </HeaderContainer>
    </VBox>
</core:FragmentDefinition>
