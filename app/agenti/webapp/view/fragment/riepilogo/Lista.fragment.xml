<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:grid="sap.ui.layout.cssgrid"
>
    <List
        width="100%"
        mode="Delete"
        growing="false"
        growingThreshold="20"
        growingScrollToLoad="true"
        sticky="HeaderToolbar,ColumnHeaders,InfoToolbar"
        items="{proposta>/table/items}"
    >
        <items>
            <CustomListItem
                type="Active"
                press=".onProductListItemPress($event, 'RIEPILOGO')"
            >
                <grid:CSSGrid>
                    <grid:customLayout>
                        <grid:GridResponsiveLayout>
                            <grid:layout>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(250px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layout>
                            <!-- <grid:layoutS>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutS>
                            <grid:layoutM>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(250px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutM>
                            <grid:layoutL>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutL>
                            <grid:layoutXL>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutXL> -->
                        </grid:GridResponsiveLayout>
                    </grid:customLayout>
                    <HBox
                        alignItems="Center"
                        class="sapUiTinyMarginTop"
                    >
                        <Image
                            visible="{proposta>/table/toolbar/showImages}"
                            class="circularImage sapUiTinyMarginEnd"
                            src="{proposta>src}"
                            lazyLoading="true"
                            width="50px"
                            press=".onShowPhotoPress"
                        >
                            <detailBox>
                                <LightBox>
                                    <LightBoxItem
                                        imageSrc="{proposta>src}"
                                        alt="Beamer"
                                        title="This is a beamer"
                                        subtitle="This is beamer's description"
                                    />
                                </LightBox>
                            </detailBox>
                        </Image>
                        <VBox>
                            <ObjectStatus
                                inverted="true"
                                state="Indication12"
                                text="{proposta>category}"
                            />
                            <Label
                                design="Bold"
                                wrapping="true"
                                text="{proposta>product} - {proposta>description}"
                            />
                        </VBox>
                    </HBox>
                    <VBox justifyContent="Center">
                        <Label
                            wrapping="true"
                            design="Bold"
                            text="Prezzo unitario: {proposta>price}"
                        />
                        <Label
                            wrapping="true"
                            design="Bold"
                            text="Valore totale di riga: {proposta>quantity}"
                        />
                        <Label
                            wrapping="true"
                            design="Bold"
                            text="Aliquota IVA: {proposta>quantity}"
                        />
                    </VBox>
                    <VBox justifyContent="Center">
                        <Label
                            design="Bold"
                            text="Quantità selezionata"
                        />
                        <StepInput
                            width="80%"
                            min="0"
                        />
                    </VBox>
                </grid:CSSGrid>
            </CustomListItem>
        </items>
    </List>
</core:FragmentDefinition>
