<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:grid="sap.ui.layout.cssgrid"
>
    <List
        width="100%"
        mode="Delete"
        growing="false"
        growingThreshold="20"
        growingScrollToLoad="true"
        sticky="HeaderToolbar,ColumnHeaders,InfoToolbar"
        items="{riepilogo>/table/items}"
    >
        <items>
            <CustomListItem
                type="Active"
                press=".onProductListItemPress($event, 'RIEPILOGO')"
            >
                <grid:CSSGrid>
                    <grid:customLayout>
                        <grid:GridResponsiveLayout>
                            <grid:layout>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(250px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layout>
                        </grid:GridResponsiveLayout>
                    </grid:customLayout>
                    <HBox
                        alignItems="Center"
                        class="sapUiTinyMargin"
                    >
                        <Image
                            visible="{proposta>/table/toolbar/showImages}"
                            class="circularImage sapUiTinyMarginEnd"
                            src="{riepilogo>src}"
                            lazyLoading="true"
                            width="50px"
                            press=".onShowPhotoPress"
                        >
                            <detailBox>
                                <LightBox>
                                    <LightBoxItem
                                        imageSrc="{riepilogo>src}"
                                        alt="Beamer"
                                        title="This is a beamer"
                                        subtitle="This is beamer's description"
                                    />
                                </LightBox>
                            </detailBox>
                        </Image>
                        <VBox>
                            <ObjectStatus
                                inverted="true"
                                state="Indication12"
                                text="{riepilogo>category}"
                            />
                            <Label
                                design="Bold"
                                wrapping="true"
                                text="{riepilogo>product} - {riepilogo>description}"
                            />
                        </VBox>
                    </HBox>
                    <VBox
                        justifyContent="Center"
                        class="sapUiTinyMargin"
                    >
                        <HBox alignItems="Start">
                            <Label
                                text="Prezzo: {riepilogo>listino} €/pz"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <ObjectNumber
                                inverted="false"
                                number="IVA 22"
                                unit="%"
                                state="Warning"
                            />
                        </HBox>
                        <ObjectNumber
                            inverted="false"
                            number="Totale: { parts: ['riepilogo>listino', 'riepilogo>quantity'], formatter: '.formatter.calculateTotal'}"
                            unit="EUR"
                            state="Information"
                        />
                    </VBox>
                    <VBox
                        justifyContent="Center"
                        class="sapUiTinyMargin"
                    >
                        <Label
                            design="Bold"
                            text="Quantità selezionata"
                        />
                        <StepInput
                            width="80%"
                            value="{riepilogo>quantity}"
                            change=".onStepInputChange"
                            min="0"
                        />
                    </VBox>
                </grid:CSSGrid>
            </CustomListItem>
        </items>
    </List>
</core:FragmentDefinition>
