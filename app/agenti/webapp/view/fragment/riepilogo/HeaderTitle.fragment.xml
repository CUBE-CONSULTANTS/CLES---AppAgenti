<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
>
    <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:snappedHeading>
            <HBox
                alignItems="Center"
                renderType="Bare"
            >
                <Button
                    class="sapUiTinyMarginEnd"
                    text="Indietro"
                    type="Emphasized"
                    icon="sap-icon://nav-back"
                    press=".onNavMain"
                />
                <Title text="{proposta>/objectPageLayout/title}" />
            </HBox>
        </uxap:snappedHeading>
        <uxap:expandedHeading>
            <HBox
                alignItems="Center"
                renderType="Bare"
            >
                <Button
                    class="sapUiTinyMarginEnd"
                    text="Indietro"
                    type="Emphasized"
                    icon="sap-icon://nav-back"
                    press=".onNavMain"
                />
                <Title text="{proposta>/objectPageLayout/title}" />
            </HBox>
        </uxap:expandedHeading>
        <uxap:snappedContent>
            <HBox
                wrap="Wrap"
                alignItems="Center"
            >
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.common.ObjectStatusCustomer"
                />
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.common.ObjectStatusTitle"
                />
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.common.ObjectStatusDate"
                />
                <ObjectNumber
                    class="sapUiTinyMarginTop sapUiTinyMarginEnd"
                    state="Success"
                    inverted="true"
                    number="Totale Imponibile 270.00"
                    unit="€"
                    emphasized="true"
                />
                <ObjectNumber
                    class="sapUiTinyMarginTop sapUiTinyMarginEnd"
                    state="Warning"
                    inverted="true"
                    number="Totale IVA 329.40"
                    unit="€"
                    emphasized="true"
                />
            </HBox>
        </uxap:snappedContent>
        <uxap:navigationActions>
            <core:Fragment
                fragmentName="cles.agenti.view.fragment.common.ExternalLinks"
                type="XML"
            />
        </uxap:navigationActions>
        <uxap:actions>
            <Button
                text="Segnalazioni"
                type="Critical"
                tooltip="Apre il menù delle segnalazioni"
                icon="sap-icon://warning"
                press=".onReportPress"
            />
            <Button
                text="Allegati"
                type="Emphasized"
                tooltip="Carica allegati di testata"
                icon="sap-icon://attachment"
                press=".onHeaderAttachmentPress"
            />
        </uxap:actions>
    </uxap:ObjectPageDynamicHeaderTitle>
</core:FragmentDefinition>
