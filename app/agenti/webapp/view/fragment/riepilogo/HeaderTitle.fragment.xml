    <f:DynamicPageTitle areaShrinkRatio="1:2:2">
        <f:heading>
            <HBox
                height="100%"
                alignItems="Center"
                renderType="Bare"
            >
                <Button
                    visible="{device>/system/desktop}"
                    class="sapUiTinyMarginEnd"
                    type="Emphasized"
                    icon="sap-icon://nav-back"
                    press=".onNavMain"
                />
                <Title
                    wrapping="true"
                    text="{proposta>/objectPageLayout/title}"
                />
            </HBox>
        </f:heading>
        <f:snappedContent>
            <HBox
                wrap="Wrap"
                alignItems="Center"
            >
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.common.ObjectStatusCustomer"
                />
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.common.ObjectStatusTitle"
                />
                <core:Fragment
                    fragmentName="cles.agenti.view.fragment.common.ObjectStatusDate"
                />
                <ObjectNumber
                    class="sapUiTinyMarginTop sapUiTinyMarginEnd"
                    state="Success"
                    inverted="true"
                    number="Totale Imponibile {riepilogo>/table/totaleNetto}"
                    unit="€"
                    emphasized="true"
                />
                <ObjectNumber
                    class="sapUiTinyMarginTop sapUiTinyMarginEnd"
                    state="Warning"
                    inverted="true"
                    number="Totale IVA {riepilogo>/table/totaleLordo}"
                    unit="€"
                    emphasized="true"
                />
            </HBox>
        </f:snappedContent>
        <f:content />
        <f:actions>
            <core:Fragment
                fragmentName="cles.agenti.view.fragment.common.Actions"
            />
        </f:actions>
        <f:navigationActions>
            <Button
                visible="{= ${device>/system/desktop} ? false : true }"
                text="Indietro"
                type="Emphasized"
                icon="sap-icon://nav-back"
                press=".onNavMain"
            />
            <core:Fragment
                fragmentName="cles.agenti.view.fragment.common.ExternalLinks"
            />
        </f:navigationActions>
    </f:DynamicPageTitle>
</core:FragmentDefinition>
