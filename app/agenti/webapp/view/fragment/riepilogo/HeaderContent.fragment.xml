<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:card="sap.f.cards"
>
    <f:Card>
        <f:header>
            <card:Header
                title="{proposta>/header/customer/name}"
                iconSrc="sap-icon://customer"
                subtitle="Articoli selezionati: ({proposta>/table/items/length})"
            />
        </f:header>
        <f:content>
            <HBox
                wrap="Wrap"
                justifyContent="SpaceAround"
                alignItems="Center"
            >
                <VBox class="sapUiTinyMarginBegin">
                    <HBox>
                        <ObjectStatus
                            class="sapUiTinyMargin"
                            text="PARTITE SCADUTE"
                            active="false"
                            inverted="true"
                            state="Error"
                            icon="sap-icon://warning"
                        />
                        <ObjectStatus
                            class="sapUiTinyMargin"
                            text="FIDO TRA 1% E 2%"
                            active="false"
                            inverted="true"
                            state="Warning"
                            icon="sap-icon://warning"
                        />
                    </HBox>
                    <HBox
                        class="sapUiSmallMarginTop sapUiTinyMarginBegin"
                        alignItems="Center"
                    >
                        <VBox class="sapUiTinyMarginBottom">
                            <Label
                                design="Bold"
                                text="Totale Imponibile:"
                            />
                            <ObjectNumber
                                state="Success"
                                inverted="true"
                                number="270.00"
                                unit="€"
                                emphasized="true"
                            />
                        </VBox>
                        <VBox
                            class="sapUiSmallMarginBegin sapUiTinyMarginBottom"
                        >
                            <Label
                                design="Bold"
                                text="Totale IVA:"
                            />
                            <ObjectNumber
                                state="Warning"
                                inverted="true"
                                number="329.40"
                                unit="€"
                                emphasized="true"
                            />
                        </VBox>
                    </HBox>
                </VBox>
                <VBox class="sapUiTinyMarginBegin">
                    <form:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="12"
                        labelSpanL="12"
                        labelSpanM="12"
                        labelSpanS="12"
                        adjustLabelSpan="false"
                    >
                        <Label text="Note ordine" />
                        <TextArea
                            value="{proposta>/header/notes}"
                            placeholder="Aggiungi note per l'ordine..."
                            rows="4"
                        />
                    </form:SimpleForm>
                </VBox>
            </HBox>
        </f:content>
    </f:Card>
</core:FragmentDefinition>
