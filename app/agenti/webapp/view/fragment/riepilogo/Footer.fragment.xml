<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <OverflowToolbar>
        <ToolbarSpacer />
        <Button
            class="sapUiTinyMargin"
            text="Crea Ordine"
            visible="{= ${proposta>/header/mode} === 'ORDINE' ? true : false }"
            type="Emphasized"
            icon="sap-icon://sales-order"
            press=".onRiepilogoPress"
        />
        <Button
            class="sapUiTinyMargin"
            text="Crea Offerta"
            visible="{= ${proposta>/header/mode} === 'OFFERTA' ? true : false }"
            type="Emphasized"
            icon="sap-icon://sales-quote"
            press=".onRiepilogoPress"
        />
        <Button
            class="sapUiTinyMargin"
            text="Crea Preordine"
            visible="{= ${proposta>/header/mode} === 'PREORDINE' ? true : false }"
            type="Emphasized"
            icon="sap-icon://sales-document"
            press=".onRiepilogoPress"
        />
        <Button
            class="sapUiTinyMargin"
            text="{= ${proposta>/header/mode} === 'SKIP' ? 'Scegli Modalità' : 'Cambia Modalità' }"
            type="Critical"
            icon="sap-icon://journey-change"
            press=".onCambioModalitaPress"
        />
    </OverflowToolbar>
</core:FragmentDefinition>
