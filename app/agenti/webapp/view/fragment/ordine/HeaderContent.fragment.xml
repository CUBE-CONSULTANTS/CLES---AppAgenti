<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <core:Fragment
        fragmentName="cles.agenti.view.fragment.common.ObjectStatusCustomer"
    />
    <core:Fragment
        fragmentName="cles.agenti.view.fragment.common.ObjectStatusTitle"
    />
    <VBox
        class="sapUiTinyMarginTop"
        visible="{= (${proposta>/header/mode} === 'ORDINE' || ${proposta>/header/mode} === 'SKIP') ? false : true }"
    >
        <ObjectStatus
            text="{
              path: 'proposta>/header/date/value',
              formatter: '.formatter.formatDate' 
            }"
            inverted="true"
            active="false"
            state="Indication12"
        />
    </VBox>
    <HBox>
        <ObjectStatus
            class="sapUiTinyMarginTop"
            text="PARTITE SCADUTE"
            active="false"
            inverted="true"
            state="Error"
            icon="sap-icon://warning"
        />
        <ObjectStatus
            class="sapUiTinyMarginTop sapUiTinyMarginBegin"
            text="FIDO TRA 1% E 2%"
            active="false"
            inverted="true"
            state="Warning"
            icon="sap-icon://warning"
        />
    </HBox>
    <core:Fragment
        fragmentName="cles.agenti.view.fragment.common.FilterBar"
        type="XML"
    />
</core:FragmentDefinition>
