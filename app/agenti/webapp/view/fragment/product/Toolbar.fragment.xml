<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <OverflowToolbar>
        <ToolbarSpacer />
        <Button
            class="sapUiTinyMargin"
            text="Allegati Prodotto"
            icon="sap-icon://attachment"
            press=".onShowProductAttachmentsPress"
        />
        <Button
            class="sapUiTinyMargin"
            text="Dettagli Prodotto"
            icon="sap-icon://information"
            press=".onShowProductDetailPress"
        />
    </OverflowToolbar>
</core:FragmentDefinition>
