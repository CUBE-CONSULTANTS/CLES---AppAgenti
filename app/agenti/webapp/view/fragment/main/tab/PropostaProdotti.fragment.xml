<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:grid="sap.ui.layout.cssgrid"
>
    <List
        id="proposta_list"
        width="100%"
        mode="None"
        growing="false"
        sticky="HeaderToolbar,ColumnHeaders,InfoToolbar"
        items="{
          path: 'proposta>/table/items', 
          templateShareable: false,
          sorter: {
            path: 'category',
            descending: false,
            group: '.getGroup'
          },
          groupHeaderFactory: '.getGroupFactory'
        }"
    >
        <headerToolbar>
            <core:Fragment
                fragmentName="cles.agenti.view.fragment.common.HeaderToolbar"
                type="XML"
            />
        </headerToolbar>
        <items>
            <CustomListItem
                type="Active"
                press=".onProductListItemPress($event, 'LISTA')"
            >
                <customData>
                    <core:CustomData
                        key="customListItemClass"
                        value="{= ${proposta>quantity} > 0 ? 'coloredListItem' : '' }"
                        writeToDom="true"
                    />
                </customData>
                <grid:CSSGrid>
                    <grid:customLayout>
                        <grid:GridResponsiveLayout>
                            <grid:layout>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layout>
                            <!-- <grid:layoutS>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutS>
                            <grid:layoutM>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(250px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutM>
                            <grid:layoutL>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutL>
                            <grid:layoutXL>
                                <grid:GridSettings
                                    gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))"
                                    gridGap="0.5rem"
                                />
                            </grid:layoutXL> -->
                        </grid:GridResponsiveLayout>
                    </grid:customLayout>
                    <VBox
                        justifyContent="Center"
                        visible="{= ${proposta>/table/toolbar/sorters/groupedByCategory} ? false : true }"
                    >
                        <ObjectStatus
                            inverted="true"
                            state="Indication12"
                            text="{proposta>category}"
                        />
                    </VBox>
                    <HBox
                        alignItems="Center"
                        class="sapUiTinyMarginTop"
                    >
                        <Image
                            visible="{proposta>/table/toolbar/showImages}"
                            class="circularImage sapUiTinyMarginEnd"
                            src="{proposta>src}"
                            lazyLoading="true"
                            width="50px"
                            press=".onShowPhotoPress"
                        >
                            <detailBox>
                                <LightBox>
                                    <LightBoxItem
                                        imageSrc="{proposta>src}"
                                        alt="Beamer"
                                        title="This is a beamer"
                                        subtitle="This is beamer's description"
                                    />
                                </LightBox>
                            </detailBox>
                        </Image>
                        <VBox>
                            <Label
                                design="Bold"
                                wrapping="true"
                                text="{proposta>product} - {proposta>description}"
                            />
                            <Label
                                design="Bold"
                                wrapping="true"
                                text="Ultimo acquisto: {proposta>u_acq}"
                            />
                        </VBox>
                    </HBox>
                    <VBox justifyContent="Center">
                        <HBox
                            alignContent="Center"
                            alignItems="Center"
                        >
                            <Link
                                class="noText"
                                reactiveAreaMode="Overlay"
                                ariaHasPopup="Dialog"
                                emphasized="true"
                                target="_self"
                                icon="sap-icon://information"
                                text="-"
                                emptyIndicatorMode="Off"
                                tooltip="Indica la giacenza del materiale indicato"
                                press=".onInfoLinkIconPress"
                            />
                            <Label
                                design="Bold"
                                text="Disponibilità: {proposta>disponibilita}"
                            />
                        </HBox>

                        <ProgressIndicator
                            percentValue="{= 
                              ${proposta>disponibilita} &lt; 1 ? '0' :
                              ${proposta>disponibilita} &lt; 5 ? '25' :
                              ${proposta>disponibilita} &lt; 10 ? '50' :
                              '75'
                            }"
                            showValue="false"
                            state="{= 
                              ${proposta>disponibilita} &lt; 5 ? 'Error' :
                              ${proposta>disponibilita} &lt; 10 ? 'Warning' :
                              'Success'
                            }"
                        />
                    </VBox>
                    <VBox justifyContent="Center">
                        <StepInput
                            value="{proposta>quantity}"
                            max="{proposta>disponibilita}"
                            min="0"
                        />
                    </VBox>
                </grid:CSSGrid>
                <HBox
                    visible="{proposta>/table/toolbar/showAttributes}"
                    class="sapUiTinyMarginTop"
                    wrap="Wrap"
                    items="{proposta>attributes}"
                >
                    <ObjectStatus
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        text="{proposta>status_text}"
                        active="true"
                        inverted="true"
                        state="{proposta>status_state}"
                    />
                </HBox>
            </CustomListItem>
        </items>
    </List>
</core:FragmentDefinition>
