<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <OverflowToolbar >
        <Button
            text="Utente"
            type="Emphasized"
            icon="sap-icon://user-settings"
        />
        <ToolbarSpacer />
        <Button
            icon="sap-icon://cart"
            type="Emphasized"
            badgeStyle="Default"
            text="Riepilogo"
            press=".onRiepilogoPress"
        >
            <customData>
                <BadgeCustomData
                    writeToDom="true"
                    value="{riepilogo>/table/items/length}"
                />
            </customData>
        </Button>
    </OverflowToolbar>
</core:FragmentDefinition>
