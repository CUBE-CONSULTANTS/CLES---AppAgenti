    <uxap:ObjectPageLayout
        showEditHeaderButton="false"
        showTitleInHeaderContent="false"
        alwaysShowContentHeader="false"
        useIconTabBar="true"
        backgroundDesignAnchorBar="Transparent"
        preserveHeaderStateOnScroll="false"
        headerContentPinnable="false"
        isChildPage="false"
        upperCaseAnchorBar="true"
        showHeaderContent="false"
        showFooter="true"
        toggleHeaderOnTitleClick="true"
        flexEnabled="true"
        useTwoColumnsForLargeScreen="true"
        selectedSection="dettagli"
    >
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:heading>
                    <HBox alignItems="Center">
                        <Avatar
                            src="{product>/carousel/pages/0/src}"
                            displaySize="S"
                            displayShape="Square"
                            class="sapUiTinyMarginEnd"
                        />
                        <Title
                            text="{product>/product/id} - {product>/product/description}"
                            wrapping="true"
                        />
                    </HBox>
                </uxap:heading>
                <uxap:navigationActions>
                    <m:OverflowToolbarButton
                        class="sapUiSmallMarginTop"
                        type="Transparent"
                        icon="sap-icon://decline"
                        press=".onClosePress"
                    />
                </uxap:navigationActions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
        <uxap:sections>
            <uxap:ObjectPageSection
                id="dettagli"
                title="Dettagli"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <core:Fragment
                            fragmentName="cles.agenti.view.fragment.product.Form"
                            type="XML"
                        />
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection
                title="Dettagli"
                visible="{= ${product>/from} === 'CATALOGO' ? true : false }"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection
                title="Note ({product>/product/notes/length})"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <form:SimpleForm>
                            <Label
                                text="Istruzione di Produzione"
                                design="Bold"
                            />
                            <TextArea
                                rows="4"
                                value="{product>/product/notes/0/nota_1}"
                            />
                            <Label
                                text="Note di imballaggio"
                                design="Bold"
                            />
                            <TextArea rows="4" />
                            <Label
                                text="Appunto posizione"
                                design="Bold"
                            />
                            <TextArea rows="4" />
                        </form:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection
                title="Storico"
                visible="{= (${product>/from} === 'LISTA' &amp;&amp; ${proposta>/header/mode} === 'ORDINE') ? true : false }"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <core:Fragment
                            fragmentName="cles.agenti.view.fragment.product.Storico"
                            type="XML"
                        />
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection title="Informazioni aggiuntive">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        visible="{= (${product>/from} === 'LISTA' || ${product>/from} === 'RIEPILOGO') ? true : false }"
                    >
                        <form:SimpleForm
                            layout="ResponsiveGridLayout"
                            columnsXL="1"
                            columnsL="1"
                            columnsM="1"
                            labelSpanXL="3"
                            labelSpanL="3"
                            labelSpanM="4"
                            labelSpanS="12"
                            emptySpanXL="1"
                            emptySpanL="1"
                            emptySpanM="0"
                            emptySpanS="0"
                            editable="false"
                        >
                            <!-- Identificazione -->
                            <core:Title text="Identificazione Prodotto" />
                            <Label text="Codice Materiale" />
                            <Text text="PRD-002345" />
                            <Label text="Descrizione" />
                            <Text
                                text="Bastoncini di mozzarella panati surgelati"
                            />
                            <Label text="Categoria" />
                            <Text text="Prodotti panati surgelati" />
                            <Label text="Marchio / Produttore" />
                            <Text text="Pastificio e Latticini Italia S.p.A." />
                            <Label text="Codice EAN" />
                            <Text text="8001234567895" />

                            <!-- Informazioni Legali e Normative -->
                            <core:Title
                                text="Informazioni Legali e Normative"
                            />
                            <Label text="Ingredienti" />
                            <Text
                                text="Mozzarella (50%) [latte, sale, caglio], panatura [farina di grano, farina di mais, amido, uovo in polvere, paprica, lievito, sale], olio di semi di girasole, acqua."
                            />
                            <Label text="Allergeni" />
                            <Text
                                text="Latte, uova, glutine. Può contenere tracce di soia e sedano."
                            />
                            <Label text="Valori Nutrizionali (100 g)" />
                            <Text
                                text="Energia 943 kJ / 225 kcal • Grassi 9,0 g (saturi 5,8 g) • Carboidrati 23 g (zuccheri 2,5 g) • Fibre 2,2 g • Proteine 12 g • Sale 1,5 g"
                            />
                        </form:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <uxap:ObjectPageSection title="Allegati">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <core:Fragment
                            fragmentName="cles.agenti.view.fragment.product.Carousel"
                            type="XML"
                        />
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
